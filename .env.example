# Konfigurasi Aplikasi
APP_NAME=SIPALET
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# Pengaturan Bahasa
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Mode Maintenance
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database
# PHP_CLI_SERVER_WORKERS=4

# Keamanan Password
BCRYPT_ROUNDS=12

# Konfigurasi Log
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Konfigurasi Database PostgreSQL (Lokal Laragon)
# DB_CONNECTION=pgsql
# DB_HOST=127.0.0.1
# DB_PORT=5432
# DB_DATABASE=sipalet
# DB_USERNAME=postgres
# DB_PASSWORD=

# Konfigurasi Database PostgreSQL (Supabase)
DB_CONNECTION=pgsql
DB_HOST=
DB_PORT=6543
DB_DATABASE=postgres
DB_USERNAME=
DB_PASSWORD=

# Kredensial Zoom API
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_ACCOUNT_ID=

# Konfigurasi Sesi
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Konfigurasi Broadcast, Storage, dan Queue
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# Konfigurasi Cache
CACHE_STORE=database
# CACHE_PREFIX=

# Konfigurasi Memcached (tidak digunakan)
MEMCACHED_HOST=127.0.0.1

# Konfigurasi Redis (tidak digunakan)
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Konfigurasi Email (tidak digunakan)
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Konfigurasi AWS S3 (tidak digunakan)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Konfigurasi Vite
VITE_APP_NAME="${APP_NAME}"
